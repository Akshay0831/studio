# Example environment configuration for Artifex Studio
# Copy this file to .env and fill in your actual API keys

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True

# GPU Configuration
GPU_DEVICE=0
FORCE_CPU=False
MAX_VRAM_PERCENTAGE=0.9

# Data Paths
PROJECTS_PATH=./data/projects
CONFIGS_PATH=./data/config
OUTPUT_PATH=./data/output
MODELS_PATH=./data/models
DATA_PATH=./data

# API Keys - Add your actual API keys here
# Replicate API
REPLICATE_API_KEY=your_replicate_api_key_here

# RunPod API  
RUNPOD_API_KEY=your_runpod_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Model Paths
DIFFUSION_MODEL_PATH=./data/models/diffusion
AUDIO_MODEL_PATH=./data/models/audio

# Security
SECRET_KEY=your_secret_key_here_for_session_management
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Caching
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
ENABLE_TELEMETRY=true
LOG_LEVEL=INFO